{
	"name": "store",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types --check && vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"gen": "wrangler types",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@fontsource-variable/geist": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.8.0",
		"@neondatabase/serverless": "latest",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "latest",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24.12.2",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"mode-watcher": "^1.1.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.8",
		"wrangler": "^4.83.0"
	},
	"dependencies": {
		"@better-auth/infra": "^0.2.4",
		"@dodopayments/sveltekit": "^0.2.6",
		"better-auth": "^1.6.5",
		"dodopayments-checkout": "^1.8.0",
		"resend": "^6.12.0",
		"zod": "^4.3.6"
	}
}
